audio:
  sample_rate: 48000
  chunk_size: 1024

  squelch_threshold: -40
  squelch_hysteresis_db: 3.0
  squelch_hang_time: 0.25

  carrier_validity_min_delta: 0.1
  carrier_validity_timeout_sec: 2.5

  highpass_enabled: true
  highpass_cutoff: 300

  limiter_enabled: true
  limiter_threshold: 0.85

  compressor_enabled: true
  compressor_strength: 50
  compressor_attack_ms: 10
  compressor_release_ms: 200
  compressor_ratio: 3.0
  compressor_threshold_db: -18
  compressor_makeup_db: 3

  dual_output: false
  output_device_2: null

  notch_enabled: false
  notch_frequency_hz: 60.0
  notch_q: 30.0
  notch_harmonics: 1


repeater:
  auto_start: true
  tail_time: 2.0
  anti_kerchunk_time: 0
  carrier_delay: 0
  courtesy_tone_enabled: true
  courtesy_tone_volume: 100


identification:
  interval_minutes: 10
  cw_enabled: true
  callsign: YOUR_CALLSIGN
  cw_pitch: 523
  cw_wpm: 20
  cw_volume: 100


tot:
  tot_enabled: true
  tot_time: 180
  tot_volume: 100
  tot_lockout_enabled: true
  tot_lockout_time: 5
  tot_tone_freq: 1200


ptt:
  dual_ptt: true

  primary:
    mode: CM108
    device_path: /dev/hidrawX
    gpio_pin: "3"

  secondary:
    mode: CM108
    device_path: /dev/ttyUSBX
    gpio_pin: "3"
